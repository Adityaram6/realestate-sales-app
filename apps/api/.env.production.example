# Copy these into Railway → Service → Variables
# Use ${{ ServiceName.VARIABLE }} syntax for cross-service references.

NODE_ENV=production
PORT=${{ PORT }}
API_PREFIX=api

# --- Database: Railway Postgres add-on ---
DATABASE_URL=${{ Postgres.DATABASE_URL }}

# --- Auth: generate long random strings (min 32 chars). Use `openssl rand -hex 32` ---
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_LONG_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=30d

# --- CORS: your Vercel deployment URL (no trailing slash). Multiple = comma-separated ---
CORS_ORIGIN=https://<your-project>.vercel.app

# --- AI: keep mock on until Anthropic key + billing is ready ---
USE_MOCK_AI=true
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
AI_DAILY_REQUEST_LIMIT=50
AI_DAILY_TOKEN_LIMIT=50000

# --- Redis: either a full URL (Upstash: rediss://…) OR discrete host/port/password (Railway)
# Set ONLY one of these groups. REDIS_URL takes precedence.
REDIS_URL=
# Railway-style fallback:
REDIS_HOST=${{ Redis.REDISHOST }}
REDIS_PORT=${{ Redis.REDISPORT }}
REDIS_PASSWORD=${{ Redis.REDISPASSWORD }}

# --- Meta Graph API (Phase 3b — stub call until Meta Business Verification) ---
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0

# --- SMS via MSG91 (stub returns fake IDs until DLT template approved) ---
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
