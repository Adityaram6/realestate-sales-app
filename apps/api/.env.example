NODE_ENV=development
PORT=4000
API_PREFIX=api

# Postgres
DATABASE_URL="postgresql://realestate:realestate@localhost:5432/realestate?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-too"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS
CORS_ORIGIN="http://localhost:3000"

# AI — flip USE_MOCK_AI=false to call real Claude (needs ANTHROPIC_API_KEY)
USE_MOCK_AI=true
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
# Per-user daily caps (enforced by AiRateLimitGuard via Redis)
AI_DAILY_REQUEST_LIMIT=50
AI_DAILY_TOKEN_LIMIT=50000

# Redis (shared with BullMQ queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Meta Graph API (Facebook / Instagram / WhatsApp Cloud)
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0

# Meta WhatsApp Cloud API (configured via /settings/integrations UI)
# These fall back to env for local dev only.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
