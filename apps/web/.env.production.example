# Copy these into Vercel → Project → Settings → Environment Variables
# Set for Production environment (optionally Preview for PR demos)

# Point at your Railway backend URL — no trailing slash
NEXT_PUBLIC_API_URL=https://<your-project>.up.railway.app/api

# Flip to true for demo/preview deploys without a backend (uses in-memory fixtures)
NEXT_PUBLIC_USE_MOCK=false

# Optional: Google Maps Places autocomplete. Unset = plain text input.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
