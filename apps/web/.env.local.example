# API base URL for the NestJS backend
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# When true, API calls are served from in-memory mock handlers instead of the real backend.
# Keep this on until the NestJS backend is wired up.
NEXT_PUBLIC_USE_MOCK=true

# Google Maps (Phase 1 — client provides key)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
